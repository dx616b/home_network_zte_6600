ZTE_URL=http://192.168.1.1
ZTE_USERNAME=root
ZTE_PASSWORD=change_me
WAN_NAME_FILTER=internet
LISTEN_HOST=0.0.0.0
LISTEN_PORT=9105
SCRAPE_INTERVAL=15
LOG_LEVEL=INFO
# Persists WAN byte offsets across modem reboots and container restarts
STATE_FILE=/data/zte_wan_counters.json
# Reverse DNS (PTR) for client IPs when modem HostName is empty
EXPORT_CLIENTS=true
CLIENT_REVERSE_DNS=true
CLIENT_DNS_TIMEOUT=0.8
CLIENT_DNS_CACHE_SECONDS=300
