{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "ZTE modem (full)",
      "type": "link",
      "url": "/d/zte-f6600p-full",
      "icon": "dashboard",
      "targetBlank": false
    },
    {
      "title": "Main switch",
      "type": "link",
      "url": "/d/switch-main-254",
      "icon": "dashboard",
      "targetBlank": false
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["home", "wan", "switch", "zte"],
  "time": { "from": "now-24h", "to": "now" },
  "timezone": "browser",
  "title": "Home network (modem + switch)",
  "uid": "home-network-correlation",
  "version": 1,
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "pluginId": "prometheus",
        "label": "Prometheus",
        "query": "prometheus",
        "refresh": 1,
        "current": {}
      },
      {
        "name": "connection",
        "type": "query",
        "label": "WAN connection",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": {
          "query": "label_values(zte_wan_rx_bytes_total, connection)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "current": { "text": "internet", "value": "internet" }
      },
      {
        "name": "uplink_port",
        "type": "custom",
        "label": "Modem uplink port",
        "query": "Port 1",
        "options": [
          { "text": "Port 1", "value": "Port 1", "selected": true },
          { "text": "Port 2", "value": "Port 2", "selected": false },
          { "text": "Port 8", "value": "Port 8", "selected": false }
        ],
        "current": { "text": "Port 1", "value": "Port 1" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Health",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Modem exporter",
      "gridPos": { "h": 3, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "refId": "A", "expr": "zte_exporter_up" }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Switch IF-MIB",
      "gridPos": { "h": 3, "w": 4, "x": 4, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "refId": "A", "expr": "up{job=\"snmp_switch_main\", instance=\"192.168.1.254\"}" }]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Switch bridge MIB",
      "gridPos": { "h": 3, "w": 4, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "refId": "A", "expr": "up{job=\"snmp_switch_bridge\", instance=\"192.168.1.254\"}" }]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "WAN download now",
      "gridPos": { "h": 3, "w": 4, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "Mbits", "decimals": 2 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area" },
      "targets": [
        {
          "refId": "A",
          "expr": "8 * rate(zte_wan_rx_bytes_total{connection=\"$connection\"}[$__rate_interval]) / 1e6"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "WAN upload now",
      "gridPos": { "h": 3, "w": 4, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "Mbits", "decimals": 2 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area" },
      "targets": [
        {
          "refId": "A",
          "expr": "8 * rate(zte_wan_tx_bytes_total{connection=\"$connection\"}[$__rate_interval]) / 1e6"
        }
      ]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Uplink port now",
      "description": "Total Mbps on selected switch port (default Port 1 = modem cable).",
      "gridPos": { "h": 3, "w": 4, "x": 20, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "Mbits", "decimals": 2 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area" },
      "targets": [
        {
          "refId": "A",
          "expr": "(8 * rate(ifHCInOctets{instance=\"192.168.1.254\", ifName=\"$uplink_port\"}[$__rate_interval]) + 8 * rate(ifHCOutOctets{instance=\"192.168.1.254\", ifName=\"$uplink_port\"}[$__rate_interval])) / 1e6"
        }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "WAN vs switch uplink",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 4 },
      "collapsed": false
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Download: WAN vs switch uplink",
      "description": "WAN RX should track traffic on the port cabled to the modem (usually Port 1). Large gaps may mean another path or counter mismatch.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "Mbits",
          "custom": { "drawStyle": "line", "fillOpacity": 12, "lineWidth": 2, "spanNulls": true }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "WAN download" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Switch uplink in" },
            "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }]
          }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "refId": "A",
          "expr": "8 * rate(zte_wan_rx_bytes_total{connection=\"$connection\"}[$__rate_interval]) / 1e6",
          "legendFormat": "WAN download"
        },
        {
          "refId": "B",
          "expr": "8 * rate(ifHCInOctets{instance=\"192.168.1.254\", ifName=\"$uplink_port\"}[$__rate_interval]) / 1e6",
          "legendFormat": "Switch uplink in"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Upload: WAN vs switch uplink",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "Mbits",
          "custom": { "drawStyle": "line", "fillOpacity": 12, "lineWidth": 2, "spanNulls": true }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "WAN upload" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Switch uplink out" },
            "properties": [{ "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }]
          }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "refId": "A",
          "expr": "8 * rate(zte_wan_tx_bytes_total{connection=\"$connection\"}[$__rate_interval]) / 1e6",
          "legendFormat": "WAN upload"
        },
        {
          "refId": "B",
          "expr": "8 * rate(ifHCOutOctets{instance=\"192.168.1.254\", ifName=\"$uplink_port\"}[$__rate_interval]) / 1e6",
          "legendFormat": "Switch uplink out"
        }
      ]
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Top switch ports (total Mbps)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "Mbits",
          "custom": { "drawStyle": "line", "fillOpacity": 8, "lineWidth": 2, "spanNulls": true }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max", "last"] } },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(5, (8 * rate(ifHCInOctets{instance=\"192.168.1.254\"}[$__rate_interval]) + 8 * rate(ifHCOutOctets{instance=\"192.168.1.254\"}[$__rate_interval])) / 1e6)",
          "legendFormat": "{{ifName}}"
        }
      ]
    },
    {
      "id": 20,
      "type": "row",
      "title": "Devices",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 },
      "collapsed": false
    },
    {
      "id": 21,
      "type": "table",
      "title": "WiFi clients (modem)",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "custom": { "align": "auto" } } },
      "options": { "showHeader": true, "cellHeight": "sm" },
      "targets": [
        {
          "refId": "A",
          "expr": "zte_client_info_info{access=\"wlan\"}",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        { "id": "labelsToFields", "options": { "mode": "columns" } },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "Value": true, "__name__": true, "access": true, "device": true, "instance": true, "job": true, "site": true },
            "indexByName": { "ip": 0, "hostname": 1, "mac": 2 },
            "renameByName": { "ip": "IP", "hostname": "Hostname", "mac": "MAC" }
          }
        }
      ]
    },
    {
      "id": 22,
      "type": "table",
      "title": "Ethernet clients (modem)",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "custom": { "align": "auto" } } },
      "options": { "showHeader": true, "cellHeight": "sm" },
      "targets": [
        {
          "refId": "A",
          "expr": "zte_client_info_info{access=\"eth\"}",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        { "id": "labelsToFields", "options": { "mode": "columns" } },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "Value": true, "__name__": true, "access": true, "device": true, "instance": true, "job": true, "site": true },
            "indexByName": { "ip": 0, "hostname": 1, "mac": 2 },
            "renameByName": { "ip": "IP", "hostname": "Hostname", "mac": "MAC" }
          }
        }
      ]
    },
    {
      "id": 23,
      "type": "table",
      "title": "MAC → host → switch port",
      "description": "Joins switch bridge MIB with modem client list (MAC/IP/hostname). Hostname from modem or PTR when EXPORT_CLIENTS + CLIENT_REVERSE_DNS=true.",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "custom": { "align": "auto" } } },
      "options": { "showHeader": true, "cellHeight": "sm", "sortBy": [{ "desc": false, "displayName": "Port" }] },
      "targets": [
        {
          "refId": "A",
          "expr": "(label_replace(dot1dTpFdbAddress{instance=\"192.168.1.254\"} * on(instance, dot1dBasePortIfIndex) group_left(ifName) label_replace(ifOperStatus{instance=\"192.168.1.254\"}, \"dot1dBasePortIfIndex\", \"$1\", \"ifIndex\", \"(.*)\"), \"mac\", \"$1\", \"dot1dTpFdbAddress\", \"(.*)\") * on(mac) group_left(ip, hostname, dns_name, access, modem_hostname) zte_client_info_info) * on(dot1dTpFdbAddress) group_left() dot1dTpFdbStatus_info{instance=\"192.168.1.254\", dot1dTpFdbStatus=\"learned\"}",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        { "id": "labelsToFields", "options": { "mode": "columns" } },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Value": true,
              "__name__": true,
              "access": true,
              "device": true,
              "dot1dBasePortIfIndex": true,
              "dot1dTpFdbPort": true,
              "instance": true,
              "job": true,
              "mac": true,
              "modem_hostname": true,
              "site": true
            },
            "indexByName": {
              "dot1dTpFdbAddress": 0,
              "ifName": 1,
              "ip": 2,
              "hostname": 3,
              "dns_name": 4
            },
            "renameByName": {
              "dot1dTpFdbAddress": "MAC",
              "ifName": "Port",
              "ip": "IP",
              "hostname": "Hostname",
              "dns_name": "DNS (PTR)"
            }
          }
        }
      ]
    },
    {
      "id": 30,
      "type": "row",
      "title": "Errors",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 30 },
      "collapsed": false
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Switch port errors",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 31 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "spanNulls": true } } },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(ifInErrors{instance=\"192.168.1.254\"}[$__rate_interval])",
          "legendFormat": "in {{ifName}}"
        },
        {
          "refId": "B",
          "expr": "rate(ifOutErrors{instance=\"192.168.1.254\"}[$__rate_interval])",
          "legendFormat": "out {{ifName}}"
        }
      ]
    },
    {
      "id": 32,
      "type": "timeseries",
      "title": "Modem WAN / LAN errors",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 31 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "spanNulls": true } } },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(zte_wan_errors_received_total{connection=\"$connection\"}[$__rate_interval])",
          "legendFormat": "WAN RX err"
        },
        {
          "refId": "B",
          "expr": "rate(zte_wan_errors_sent_total{connection=\"$connection\"}[$__rate_interval])",
          "legendFormat": "WAN TX err"
        },
        {
          "refId": "C",
          "expr": "rate(zte_lan_rx_errors_total[$__rate_interval])",
          "legendFormat": "LAN RX {{port}}"
        }
      ]
    }
  ]
}
