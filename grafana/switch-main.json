{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "Home network (modem + switch)",
      "type": "link",
      "url": "/d/home-network-correlation",
      "icon": "dashboard",
      "targetBlank": false
    },
    {
      "title": "ZTE modem (full)",
      "type": "link",
      "url": "/d/zte-f6600p-full",
      "icon": "dashboard",
      "targetBlank": false
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["snmp", "switch", "lan"],
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "browser",
  "title": "Main switch (192.168.1.254)",
  "uid": "switch-main-254",
  "version": 2,
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "pluginId": "prometheus",
        "label": "Prometheus",
        "query": "prometheus",
        "refresh": 1,
        "current": {}
      },
      {
        "name": "port",
        "type": "query",
        "label": "Port",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": {
          "query": "label_values(ifHCInOctets{instance=\"192.168.1.254\"}, ifName)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Switch",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "stat",
      "title": "IF-MIB scrape",
      "gridPos": { "h": 4, "w": 3, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "refId": "A", "expr": "up{job=\"snmp_switch_main\", instance=\"192.168.1.254\"}" }]
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Bridge MIB scrape",
      "gridPos": { "h": 4, "w": 3, "x": 3, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "refId": "A", "expr": "up{job=\"snmp_switch_bridge\", instance=\"192.168.1.254\"}" }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Ports up",
      "gridPos": { "h": 4, "w": 3, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 0 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none" },
      "targets": [{ "refId": "A", "expr": "count(ifOperStatus{instance=\"192.168.1.254\"} == 1)" }]
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Learned MACs",
      "gridPos": { "h": 4, "w": 3, "x": 9, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 0 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none" },
      "targets": [
        {
          "refId": "A",
          "expr": "count(dot1dTpFdbStatus_info{instance=\"192.168.1.254\", dot1dTpFdbStatus=\"learned\"})"
        }
      ]
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Switch uptime",
      "gridPos": { "h": 4, "w": 5, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none" },
      "targets": [{ "refId": "A", "expr": "sysUpTime / 100" }]
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Model",
      "gridPos": { "h": 4, "w": 7, "x": 17, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "none" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none", "textMode": "name" },
      "targets": [{ "refId": "A", "expr": "sysDescr", "legendFormat": "{{sysDescr}}" }]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Top ports throughput (Mbps)",
      "gridPos": { "h": 8, "w": 14, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "Mbits",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "spanNulls": true }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max", "last"] } },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(5, (8 * rate(ifHCInOctets{instance=\"192.168.1.254\", ifName=~\"$port\"}[$__rate_interval]) + 8 * rate(ifHCOutOctets{instance=\"192.168.1.254\", ifName=~\"$port\"}[$__rate_interval])) / 1e6)",
          "legendFormat": "{{ifName}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "table",
      "title": "Ports",
      "gridPos": { "h": 8, "w": 10, "x": 14, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Link" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "1": { "text": "up", "color": "green" } } },
                  { "type": "value", "options": { "2": { "text": "down", "color": "red" } } }
                ]
              }
            ]
          },
          { "matcher": { "id": "byName", "options": "Speed Mbps" }, "properties": [{ "id": "unit", "value": "Mbits" }] },
          { "matcher": { "id": "byName", "options": "In Mbps" }, "properties": [{ "id": "unit", "value": "Mbits" }] },
          { "matcher": { "id": "byName", "options": "Out Mbps" }, "properties": [{ "id": "unit", "value": "Mbits" }] },
          { "matcher": { "id": "byName", "options": "Util %" }, "properties": [{ "id": "unit", "value": "percent" }, { "id": "max", "value": 100 }] }
        ]
      },
      "options": { "showHeader": true, "cellHeight": "sm", "sortBy": [{ "desc": true, "displayName": "Total Mbps" }] },
      "targets": [
        { "refId": "A", "expr": "ifOperStatus{instance=\"192.168.1.254\"}", "format": "table", "instant": true },
        { "refId": "B", "expr": "ifHighSpeed{instance=\"192.168.1.254\"}", "format": "table", "instant": true },
        {
          "refId": "C",
          "expr": "8 * rate(ifHCInOctets{instance=\"192.168.1.254\"}[$__rate_interval]) / 1e6",
          "format": "table",
          "instant": true
        },
        {
          "refId": "D",
          "expr": "8 * rate(ifHCOutOctets{instance=\"192.168.1.254\"}[$__rate_interval]) / 1e6",
          "format": "table",
          "instant": true
        },
        {
          "refId": "E",
          "expr": "(8 * rate(ifHCInOctets{instance=\"192.168.1.254\"}[$__rate_interval]) + 8 * rate(ifHCOutOctets{instance=\"192.168.1.254\"}[$__rate_interval])) / 1e6",
          "format": "table",
          "instant": true
        },
        {
          "refId": "F",
          "expr": "100 * (8 * rate(ifHCInOctets{instance=\"192.168.1.254\"}[$__rate_interval]) + 8 * rate(ifHCOutOctets{instance=\"192.168.1.254\"}[$__rate_interval])) / (ifSpeed{instance=\"192.168.1.254\"} > 0)",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        { "id": "seriesToColumns", "options": { "byField": "ifName" } },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Time 1": true,
              "Time 2": true,
              "Time 3": true,
              "Time 4": true,
              "Time 5": true,
              "__name__": true,
              "device": true,
              "ifAlias": true,
              "ifDescr": true,
              "ifIndex": true,
              "instance": true,
              "job": true,
              "site": true
            },
            "renameByName": {
              "Value #A": "Link",
              "Value #B": "Speed Mbps",
              "Value #C": "In Mbps",
              "Value #D": "Out Mbps",
              "Value #E": "Total Mbps",
              "Value #F": "Util %",
              "ifName": "Port"
            }
          }
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Port throughput",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "Mbits",
          "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 2, "spanNulls": true }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "refId": "A",
          "expr": "8 * rate(ifHCInOctets{instance=\"192.168.1.254\", ifName=~\"$port\"}[$__rate_interval]) / 1e6",
          "legendFormat": "{{ifName}} in"
        },
        {
          "refId": "B",
          "expr": "8 * rate(ifHCOutOctets{instance=\"192.168.1.254\", ifName=~\"$port\"}[$__rate_interval]) / 1e6",
          "legendFormat": "{{ifName}} out"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Port errors / discards",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "spanNulls": true } } },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(ifInErrors{instance=\"192.168.1.254\", ifName=~\"$port\"}[$__rate_interval])",
          "legendFormat": "in err {{ifName}}"
        },
        {
          "refId": "B",
          "expr": "rate(ifOutErrors{instance=\"192.168.1.254\", ifName=~\"$port\"}[$__rate_interval])",
          "legendFormat": "out err {{ifName}}"
        },
        {
          "refId": "C",
          "expr": "rate(ifInDiscards{instance=\"192.168.1.254\", ifName=~\"$port\"}[$__rate_interval])",
          "legendFormat": "in discard {{ifName}}"
        }
      ]
    },
    {
      "id": 20,
      "type": "row",
      "title": "MAC table (bridge MIB)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 },
      "collapsed": false
    },
    {
      "id": 21,
      "type": "table",
      "title": "Learned MAC → host → port",
      "description": "Bridge MIB + modem client list. Hostname from modem or reverse DNS (CLIENT_REVERSE_DNS). Port 1 is usually the modem uplink.",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "custom": { "align": "auto" } } },
      "options": { "showHeader": true, "cellHeight": "sm", "sortBy": [{ "desc": false, "displayName": "Port" }] },
      "targets": [
        {
          "refId": "A",
          "expr": "(label_replace(dot1dTpFdbAddress{instance=\"192.168.1.254\"} * on(instance, dot1dBasePortIfIndex) group_left(ifName) label_replace(ifOperStatus{instance=\"192.168.1.254\"}, \"dot1dBasePortIfIndex\", \"$1\", \"ifIndex\", \"(.*)\"), \"mac\", \"$1\", \"dot1dTpFdbAddress\", \"(.*)\") * on(mac) group_left(ip, hostname, dns_name, access, modem_hostname) zte_client_info_info) * on(dot1dTpFdbAddress) group_left() dot1dTpFdbStatus_info{instance=\"192.168.1.254\", dot1dTpFdbStatus=\"learned\"}",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        { "id": "labelsToFields", "options": { "mode": "columns" } },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Value": true,
              "__name__": true,
              "access": true,
              "device": true,
              "dot1dBasePortIfIndex": true,
              "dot1dTpFdbPort": true,
              "instance": true,
              "job": true,
              "mac": true,
              "modem_hostname": true,
              "site": true
            },
            "indexByName": {
              "dot1dTpFdbAddress": 0,
              "ifName": 1,
              "ip": 2,
              "hostname": 3,
              "dns_name": 4
            },
            "renameByName": {
              "dot1dTpFdbAddress": "MAC",
              "ifName": "Port",
              "ip": "IP",
              "hostname": "Hostname",
              "dns_name": "DNS (PTR)"
            }
          }
        }
      ]
    }
  ]
}
