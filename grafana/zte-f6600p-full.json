{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "Home network (modem + switch)",
      "type": "link",
      "url": "/d/home-network-correlation",
      "icon": "dashboard",
      "targetBlank": false
    },
    {
      "title": "Main switch",
      "type": "link",
      "url": "/d/switch-main-254",
      "icon": "dashboard",
      "targetBlank": false
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["zte", "f6600p", "wan", "pon"],
  "time": { "from": "now-24h", "to": "now" },
  "timezone": "browser",
  "title": "ZTE F6600P Full Monitoring",
  "uid": "zte-f6600p-full",
  "version": 4,
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "pluginId": "prometheus",
        "label": "Prometheus",
        "query": "prometheus",
        "refresh": 1,
        "current": {}
      },
      {
        "name": "connection",
        "type": "query",
        "label": "WAN connection",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": {
          "query": "label_values(zte_wan_rx_bytes_total, connection)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "includeAll": false,
        "multi": false,
        "current": { "text": "internet", "value": "internet" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Health",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Exporter",
      "gridPos": { "h": 4, "w": 3, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red" },
                "1": { "text": "UP", "color": "green" }
              }
            }
          ]
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [{ "refId": "A", "expr": "zte_exporter_up" }]
    },
    {
      "id": 3,
      "type": "bargauge",
      "title": "Subsystem scrapes",
      "gridPos": { "h": 4, "w": 8, "x": 3, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "unit": "none",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "FAIL", "color": "red" },
                "1": { "text": "OK", "color": "green" }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "displayMode": "basic",
        "orientation": "horizontal",
        "showUnfilled": true,
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [{ "refId": "A", "expr": "zte_scrape_success", "legendFormat": "{{subsystem}}" }]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Modem uptime",
      "gridPos": { "h": 4, "w": 3, "x": 11, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "options": {
        "colorMode": "none",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [{ "refId": "A", "expr": "zte_modem_uptime_seconds" }]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "WiFi clients",
      "gridPos": { "h": 4, "w": 3, "x": 14, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 0 } },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [{ "refId": "A", "expr": "zte_wlan_clients" }]
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Ethernet clients",
      "gridPos": { "h": 4, "w": 3, "x": 17, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 0 } },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [{ "refId": "A", "expr": "zte_eth_clients" }]
    },
    {
      "id": 6,
      "type": "table",
      "title": "Modem info",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto", "inspect": false } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [{ "id": "custom.hidden", "value": true }]
          },
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [{ "id": "custom.hidden", "value": true }]
          }
        ]
      },
      "options": {
        "showHeader": false,
        "cellHeight": "sm",
        "footer": { "show": false }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "zte_modem_info_info",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        { "id": "labelsToFields", "options": { "mode": "columns" } },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "Value": true, "__name__": true },
            "renameByName": {
              "model": "Model",
              "software": "Software",
              "hardware": "Hardware",
              "serial": "Serial",
              "manufacturer": "Manufacturer"
            }
          }
        }
      ]
    },
    {
      "id": 7,
      "type": "table",
      "title": "WiFi clients",
      "description": "From modem hiddenData accessdev_data DeveiceType=WLAN. Requires EXPORT_CLIENTS=true.",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": { "show": false }
      },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto", "inspect": false } },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "zte_client_info_info{access=\"wlan\"}",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        { "id": "labelsToFields", "options": { "mode": "columns" } },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Value": true,
              "__name__": true,
              "device": true,
              "instance": true,
              "job": true,
              "site": true,
              "access": true
            },
            "indexByName": {
              "ip": 0,
              "hostname": 1,
              "dns_name": 2,
              "mac": 3,
              "modem_hostname": 4,
              "interface": 5
            },
            "renameByName": {
              "mac": "MAC",
              "hostname": "Hostname",
              "dns_name": "DNS (PTR)",
              "modem_hostname": "Modem name",
              "ip": "IP",
              "interface": "Interface"
            }
          }
        }
      ]
    },
    {
      "id": 8,
      "type": "table",
      "title": "Ethernet clients",
      "description": "From modem hiddenData accessdev_data DeveiceType=ETH.",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": { "show": false }
      },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto", "inspect": false } },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "zte_client_info_info{access=\"eth\"}",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        { "id": "labelsToFields", "options": { "mode": "columns" } },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Value": true,
              "__name__": true,
              "device": true,
              "instance": true,
              "job": true,
              "site": true,
              "access": true
            },
            "indexByName": {
              "ip": 0,
              "hostname": 1,
              "dns_name": 2,
              "mac": 3,
              "modem_hostname": 4,
              "interface": 5
            },
            "renameByName": {
              "mac": "MAC",
              "hostname": "Hostname",
              "dns_name": "DNS (PTR)",
              "modem_hostname": "Modem name",
              "ip": "IP",
              "interface": "Interface"
            }
          }
        }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "WAN traffic",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 12 },
      "collapsed": false
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "WAN throughput",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "Mbits",
          "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 2, "spanNulls": true }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max", "last"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "8 * rate(zte_wan_rx_bytes_total{connection=\"$connection\"}[$__rate_interval]) / 1e6",
          "legendFormat": "Download"
        },
        {
          "refId": "B",
          "expr": "8 * rate(zte_wan_tx_bytes_total{connection=\"$connection\"}[$__rate_interval]) / 1e6",
          "legendFormat": "Upload"
        }
      ]
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Downloaded (range)",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "bytes", "decimals": 2 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(zte_wan_rx_bytes_total{connection=\"$connection\"}[$__range]))"
        }
      ]
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Uploaded (range)",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "bytes", "decimals": 2 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(zte_wan_tx_bytes_total{connection=\"$connection\"}[$__range]))"
        }
      ]
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "WAN errors (per second)",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "spanNulls": true } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(zte_wan_errors_received_total{connection=\"$connection\"}[$__rate_interval])",
          "legendFormat": "RX errors"
        },
        {
          "refId": "B",
          "expr": "rate(zte_wan_errors_sent_total{connection=\"$connection\"}[$__rate_interval])",
          "legendFormat": "TX errors"
        }
      ]
    },
    {
      "id": 15,
      "type": "row",
      "title": "Month to date (from 1st of month)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false
    },
    {
      "id": 16,
      "type": "stat",
      "title": "MTD Download",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "timeFrom": "now/M",
      "fieldConfig": { "defaults": { "unit": "bytes", "decimals": 2 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none" },
      "targets": [
        { "refId": "A", "expr": "sum(increase(zte_wan_rx_bytes_total{connection=\"$connection\"}[$__range]))" }
      ]
    },
    {
      "id": 17,
      "type": "stat",
      "title": "MTD Upload",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "timeFrom": "now/M",
      "fieldConfig": { "defaults": { "unit": "bytes", "decimals": 2 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none" },
      "targets": [
        { "refId": "A", "expr": "sum(increase(zte_wan_tx_bytes_total{connection=\"$connection\"}[$__range]))" }
      ]
    },
    {
      "id": 18,
      "type": "stat",
      "title": "MTD Total",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "timeFrom": "now/M",
      "fieldConfig": { "defaults": { "unit": "bytes", "decimals": 2 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(zte_wan_rx_bytes_total{connection=\"$connection\"}[$__range]) + increase(zte_wan_tx_bytes_total{connection=\"$connection\"}[$__range]))"
        }
      ]
    },
    {
      "id": 19,
      "type": "stat",
      "title": "MTD Total (TB)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "timeFrom": "now/M",
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 4 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none" },
      "targets": [
        {
          "refId": "A",
          "expr": "(sum(increase(zte_wan_rx_bytes_total{connection=\"$connection\"}[$__range]) + increase(zte_wan_tx_bytes_total{connection=\"$connection\"}[$__range]))) / 1e12"
        }
      ]
    },
    {
      "id": 20,
      "type": "row",
      "title": "Fiber / PON",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 19 },
      "collapsed": false
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "PON optical power",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "dBm",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "spanNulls": true },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": -27 },
              { "color": "green", "value": -25 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "RX" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "TX" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "refId": "A", "expr": "zte_pon_rx_power_dbm", "legendFormat": "RX" },
        { "refId": "B", "expr": "zte_pon_tx_power_dbm", "legendFormat": "TX" }
      ]
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "PON temperature",
      "gridPos": { "h": 7, "w": 6, "x": 12, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "spanNulls": true }
        }
      },
      "targets": [{ "refId": "A", "expr": "zte_pon_temperature_celsius", "legendFormat": "Module temp" }]
    },
    {
      "id": 23,
      "type": "timeseries",
      "title": "PON voltage & bias",
      "gridPos": { "h": 7, "w": 6, "x": 18, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "line", "spanNulls": true } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Voltage" },
            "properties": [{ "id": "unit", "value": "mvolt" }]
          },
          {
            "matcher": { "id": "byName", "options": "Bias current" },
            "properties": [{ "id": "unit", "value": "mamp" }]
          }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "refId": "A", "expr": "zte_pon_voltage_mv", "legendFormat": "Voltage" },
        { "refId": "B", "expr": "zte_pon_bias_current_ma", "legendFormat": "Bias current" }
      ]
    },
    {
      "id": 24,
      "type": "stat",
      "title": "LOS",
      "description": "1 = loss of signal",
      "gridPos": { "h": 3, "w": 3, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "OK", "color": "green" },
                "1": { "text": "LOS", "color": "red" }
              }
            }
          ]
        }
      },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "refId": "A", "expr": "zte_pon_los" }]
    },
    {
      "id": 25,
      "type": "stat",
      "title": "GPON reg status",
      "gridPos": { "h": 3, "w": 3, "x": 3, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "refId": "A", "expr": "zte_pon_gpon_reg_status" }]
    },
    {
      "id": 26,
      "type": "stat",
      "title": "PON uptime",
      "gridPos": { "h": 3, "w": 6, "x": 6, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "refId": "A", "expr": "zte_pon_uptime_seconds" }]
    },
    {
      "id": 30,
      "type": "row",
      "title": "System & LAN",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "collapsed": false
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "CPU & memory",
      "gridPos": { "h": 7, "w": 10, "x": 0, "y": 26 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "drawStyle": "line", "fillOpacity": 10, "spanNulls": true }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "refId": "A", "expr": "zte_cpu_usage_percent", "legendFormat": "CPU {{core}}" },
        { "refId": "B", "expr": "zte_memory_usage_percent", "legendFormat": "Memory" }
      ]
    },
    {
      "id": 32,
      "type": "timeseries",
      "title": "LAN port throughput",
      "gridPos": { "h": 7, "w": 14, "x": 10, "y": 26 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "Mbits",
          "custom": { "drawStyle": "line", "fillOpacity": 5, "spanNulls": true }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "last"] } },
      "targets": [
        {
          "refId": "A",
          "expr": "8 * rate(zte_lan_rx_bytes_total[$__rate_interval]) / 1e6",
          "legendFormat": "In {{port}}"
        },
        {
          "refId": "B",
          "expr": "8 * rate(zte_lan_tx_bytes_total[$__rate_interval]) / 1e6",
          "legendFormat": "Out {{port}}"
        }
      ]
    },
    {
      "id": 33,
      "type": "table",
      "title": "LAN ports",
      "gridPos": { "h": 7, "w": 10, "x": 0, "y": 33 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Link" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "0": { "text": "Down", "color": "red" },
                      "1": { "text": "Up", "color": "green" }
                    }
                  }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Speed Mbps" },
            "properties": [{ "id": "unit", "value": "Mbits" }]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "desc": false, "displayName": "Port" }]
      },
      "targets": [
        { "refId": "A", "expr": "zte_lan_link_up", "format": "table", "instant": true, "legendFormat": "link" },
        { "refId": "B", "expr": "zte_lan_speed_mbps", "format": "table", "instant": true, "legendFormat": "speed" }
      ],
      "transformations": [
        { "id": "seriesToColumns", "options": { "byField": "port" } },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "port": "Port",
              "Value #A": "Link",
              "Value #B": "Speed Mbps"
            },
            "excludeByName": { "Time": true, "Time 1": true, "Time 2": true, "__name__": true, "__name__ 1": true }
          }
        }
      ]
    },
    {
      "id": 34,
      "type": "stat",
      "title": "VoIP lines",
      "gridPos": { "h": 7, "w": 6, "x": 10, "y": 33 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "Down", "color": "red" },
                "1": { "text": "Up", "color": "green" }
              }
            }
          ]
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [{ "refId": "A", "expr": "zte_voip_line_up", "legendFormat": "{{line}}" }]
    },
    {
      "id": 35,
      "type": "timeseries",
      "title": "LAN errors (per second)",
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 33 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "spanNulls": true } } },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(zte_lan_rx_errors_total[$__rate_interval])",
          "legendFormat": "RX err {{port}}"
        },
        {
          "refId": "B",
          "expr": "rate(zte_lan_tx_errors_total[$__rate_interval])",
          "legendFormat": "TX err {{port}}"
        }
      ]
    }
  ]
}
