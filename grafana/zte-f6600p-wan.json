{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["zte", "wan", "f6600p"],
  "time": { "from": "now-24h", "to": "now" },
  "timezone": "browser",
  "title": "ZTE F6600P — Traffic",
  "uid": "zte-f6600p-wan",
  "version": 3,
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "pluginId": "prometheus",
        "label": "Prometheus",
        "query": "prometheus",
        "refresh": 1,
        "current": {}
      },
      {
        "name": "lan_port",
        "type": "query",
        "label": "LAN port",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": {
          "query": "label_values(zte_lan_rx_bytes_total, port)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Health",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Exporter",
      "gridPos": { "h": 4, "w": 3, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "refId": "A", "expr": "zte_exporter_up" }]
    },
    {
      "id": 3,
      "type": "bargauge",
      "title": "Subsystem scrapes",
      "gridPos": { "h": 4, "w": 9, "x": 3, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "FAIL", "color": "red" }, "1": { "text": "OK", "color": "green" } } }
          ],
          "max": 1, "min": 0
        }
      },
      "options": { "displayMode": "lcd", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "refId": "A", "expr": "zte_scrape_success", "legendFormat": "{{subsystem}}" }]
    },
    {
      "id": 40,
      "type": "stat",
      "title": "Current LAN throughput",
      "description": "Total LAN port throughput (in + out) right now.",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "bps", "decimals": 1 } },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(8 * rate(zte_lan_rx_bytes_total{port=~\"$lan_port\"}[$__rate_interval])) + sum(8 * rate(zte_lan_tx_bytes_total{port=~\"$lan_port\"}[$__rate_interval]))"
        }
      ]
    },
    {
      "id": 41,
      "type": "stat",
      "title": "Current WLAN throughput",
      "description": "Total WiFi throughput (all SSIDs, in + out).",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "bps", "decimals": 1 } },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(8 * rate(zte_wlan_rx_bytes_total[$__rate_interval])) + sum(8 * rate(zte_wlan_tx_bytes_total[$__rate_interval]))"
        }
      ]
    },
    {
      "id": 42,
      "type": "stat",
      "title": "Modem uptime",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "options": { "colorMode": "none", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "refId": "A", "expr": "zte_modem_uptime_seconds" }]
    },

    {
      "id": 6,
      "type": "row",
      "title": "LAN Port Traffic (wired devices via switch)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "LAN port throughput",
      "description": "Accurate 64-bit counters on the modem Ethernet port(s). RX = data entering modem from switch (uploads from wired devices). TX = data leaving modem to switch (downloads to wired devices).",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "bps",
          "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2, "spanNulls": true, "axisSoftMin": 0 }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*RX.*" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".*TX.*" },
            "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "last"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "8 * rate(zte_lan_rx_bytes_total{port=~\"$lan_port\"}[$__rate_interval])",
          "legendFormat": "{{port}} RX (from switch)"
        },
        {
          "refId": "B",
          "expr": "8 * rate(zte_lan_tx_bytes_total{port=~\"$lan_port\"}[$__rate_interval])",
          "legendFormat": "{{port}} TX (to switch)"
        }
      ]
    },

    {
      "id": 50,
      "type": "row",
      "title": "WLAN Traffic (WiFi per SSID)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "collapsed": false
    },
    {
      "id": 51,
      "type": "timeseries",
      "title": "WLAN throughput per SSID",
      "description": "WiFi interface traffic per SSID. RX = data received by modem from WiFi clients (uploads). TX = data sent by modem to WiFi clients (downloads).",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 17 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "bps",
          "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 2, "spanNulls": true, "axisSoftMin": 0 }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*RX.*" },
            "properties": [{ "id": "custom.fillOpacity", "value": 10 }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "last"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "8 * rate(zte_wlan_rx_bytes_total[$__rate_interval])",
          "legendFormat": "{{ssid}} ({{radio}}) RX"
        },
        {
          "refId": "B",
          "expr": "8 * rate(zte_wlan_tx_bytes_total[$__rate_interval])",
          "legendFormat": "{{ssid}} ({{radio}}) TX"
        }
      ]
    },

    {
      "id": 52,
      "type": "row",
      "title": "WLAN Clients",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "collapsed": true,
      "panels": [
        {
          "id": 53,
          "type": "timeseries",
          "title": "Per-client WiFi throughput",
          "description": "Traffic per connected WiFi client by MAC address.",
          "gridPos": { "h": 10, "w": 24, "x": 0, "y": 28 },
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "fieldConfig": {
            "defaults": {
              "unit": "bps",
              "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "spanNulls": true, "axisSoftMin": 0 }
            }
          },
          "options": {
            "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max", "last"] },
            "tooltip": { "mode": "multi", "sort": "desc" }
          },
          "targets": [
            {
              "refId": "A",
              "expr": "8 * rate(zte_wlan_client_rx_bytes_total[$__rate_interval]) * on(mac) group_left(hostname, ip) topk by(mac) (1, zte_client_info_info)",
              "legendFormat": "{{hostname}} ({{ip}}) RX"
            },
            {
              "refId": "B",
              "expr": "8 * rate(zte_wlan_client_tx_bytes_total[$__rate_interval]) * on(mac) group_left(hostname, ip) topk by(mac) (1, zte_client_info_info)",
              "legendFormat": "{{hostname}} ({{ip}}) TX"
            }
          ]
        },
        {
          "id": 54,
          "type": "timeseries",
          "title": "WiFi client signal strength",
          "gridPos": { "h": 8, "w": 12, "x": 0, "y": 38 },
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "fieldConfig": {
            "defaults": {
              "unit": "dBm",
              "custom": { "drawStyle": "line", "fillOpacity": 0, "lineWidth": 2, "spanNulls": true }
            }
          },
          "options": {
            "legend": { "displayMode": "table", "placement": "right", "calcs": ["last"] },
            "tooltip": { "mode": "multi" }
          },
          "targets": [
            {
              "refId": "A",
              "expr": "zte_wlan_client_rssi_dbm * on(mac) group_left(hostname, ip) topk by(mac) (1, zte_client_info_info)",
              "legendFormat": "{{hostname}} ({{ip}})"
            }
          ]
        },
        {
          "id": 55,
          "type": "timeseries",
          "title": "WiFi client SNR",
          "gridPos": { "h": 8, "w": 12, "x": 12, "y": 38 },
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "fieldConfig": {
            "defaults": {
              "unit": "dB",
              "custom": { "drawStyle": "line", "fillOpacity": 0, "lineWidth": 2, "spanNulls": true }
            }
          },
          "options": {
            "legend": { "displayMode": "table", "placement": "right", "calcs": ["last"] },
            "tooltip": { "mode": "multi" }
          },
          "targets": [
            {
              "refId": "A",
              "expr": "zte_wlan_client_snr_db * on(mac) group_left(hostname, ip) topk by(mac) (1, zte_client_info_info)",
              "legendFormat": "{{hostname}} ({{ip}})"
            }
          ]
        }
      ]
    },

    {
      "id": 8,
      "type": "row",
      "title": "Data Usage (selected time range)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 28 },
      "collapsed": false
    },
    {
      "id": 9,
      "type": "stat",
      "title": "LAN Downloaded",
      "description": "Bytes sent from modem to switch (downloads to wired devices) in the dashboard time range.",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "bytes", "decimals": 2 } },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(zte_lan_tx_bytes_total{port=~\"$lan_port\"}[$__range]))"
        }
      ]
    },
    {
      "id": 10,
      "type": "stat",
      "title": "LAN Uploaded",
      "description": "Bytes received by modem from switch (uploads from wired devices) in the dashboard time range.",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "bytes", "decimals": 2 } },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(zte_lan_rx_bytes_total{port=~\"$lan_port\"}[$__range]))"
        }
      ]
    },
    {
      "id": 11,
      "type": "stat",
      "title": "WLAN Downloaded",
      "description": "Bytes sent by modem to WiFi clients (downloads) in the dashboard time range.",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "bytes", "decimals": 2 } },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(zte_wlan_tx_bytes_total[$__range]))"
        }
      ]
    },
    {
      "id": 12,
      "type": "stat",
      "title": "WLAN Uploaded",
      "description": "Bytes received by modem from WiFi clients (uploads) in the dashboard time range.",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "bytes", "decimals": 2 } },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(zte_wlan_rx_bytes_total[$__range]))"
        }
      ]
    },

    {
      "id": 14,
      "type": "row",
      "title": "Month to date (from 1st of month)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 34 },
      "collapsed": false
    },
    {
      "id": 15,
      "type": "stat",
      "title": "MTD LAN Download",
      "description": "LAN port download since start of month (modem to switch).",
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 35 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "timeFrom": "now/M",
      "fieldConfig": { "defaults": { "unit": "bytes", "decimals": 2 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none" },
      "targets": [
        { "refId": "A", "expr": "sum(increase(zte_lan_tx_bytes_total{port=~\"$lan_port\"}[$__range]))", "instant": true, "range": false }
      ]
    },
    {
      "id": 16,
      "type": "stat",
      "title": "MTD LAN Upload",
      "description": "LAN port upload since start of month (switch to modem).",
      "gridPos": { "h": 5, "w": 4, "x": 4, "y": 35 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "timeFrom": "now/M",
      "fieldConfig": { "defaults": { "unit": "bytes", "decimals": 2 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none" },
      "targets": [
        { "refId": "A", "expr": "sum(increase(zte_lan_rx_bytes_total{port=~\"$lan_port\"}[$__range]))", "instant": true, "range": false }
      ]
    },
    {
      "id": 17,
      "type": "stat",
      "title": "MTD WLAN Download",
      "description": "WiFi download since start of month (modem to WiFi clients).",
      "gridPos": { "h": 5, "w": 4, "x": 8, "y": 35 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "timeFrom": "now/M",
      "fieldConfig": { "defaults": { "unit": "bytes", "decimals": 2 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none" },
      "targets": [
        { "refId": "A", "expr": "sum(increase(zte_wlan_tx_bytes_total[$__range]))", "instant": true, "range": false }
      ]
    },
    {
      "id": 18,
      "type": "stat",
      "title": "MTD WLAN Upload",
      "description": "WiFi upload since start of month (WiFi clients to modem).",
      "gridPos": { "h": 5, "w": 4, "x": 12, "y": 35 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "timeFrom": "now/M",
      "fieldConfig": { "defaults": { "unit": "bytes", "decimals": 2 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none" },
      "targets": [
        { "refId": "A", "expr": "sum(increase(zte_wlan_rx_bytes_total[$__range]))", "instant": true, "range": false }
      ]
    },
    {
      "id": 19,
      "type": "stat",
      "title": "MTD Total (LAN+WLAN)",
      "description": "Combined LAN + WLAN total traffic since start of month.",
      "gridPos": { "h": 5, "w": 4, "x": 16, "y": 35 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "timeFrom": "now/M",
      "fieldConfig": { "defaults": { "unit": "bytes", "decimals": 2 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none" },
      "targets": [
        { "refId": "A", "expr": "sum(increase(zte_lan_rx_bytes_total[$__range])) + sum(increase(zte_lan_tx_bytes_total[$__range])) + sum(increase(zte_wlan_rx_bytes_total[$__range])) + sum(increase(zte_wlan_tx_bytes_total[$__range]))", "instant": true, "range": false }
      ]
    },
    {
      "id": 20,
      "type": "stat",
      "title": "MTD Total (TB)",
      "description": "Combined LAN + WLAN total in terabytes.",
      "gridPos": { "h": 5, "w": 4, "x": 20, "y": 35 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "timeFrom": "now/M",
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 4 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none" },
      "targets": [
        { "refId": "A", "expr": "(sum(increase(zte_lan_rx_bytes_total[$__range])) + sum(increase(zte_lan_tx_bytes_total[$__range])) + sum(increase(zte_wlan_rx_bytes_total[$__range])) + sum(increase(zte_wlan_tx_bytes_total[$__range]))) / 1e12", "instant": true, "range": false }
      ]
    },

    {
      "id": 60,
      "type": "row",
      "title": "WAN PPPoE (broken counters — reference only)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 40 },
      "collapsed": true,
      "panels": [
        {
          "id": 61,
          "type": "timeseries",
          "title": "WAN PPPoE throughput (BROKEN)",
          "description": "These PPPoE byte counters are broken on this firmware. They only count control-plane traffic, NOT actual internet data. Shown for reference only.",
          "gridPos": { "h": 8, "w": 24, "x": 0, "y": 41 },
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "fieldConfig": {
            "defaults": {
              "unit": "bps",
              "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "spanNulls": true }
            },
            "overrides": [
              { "matcher": { "id": "byName", "options": "PPPoE RX" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
              { "matcher": { "id": "byName", "options": "PPPoE TX" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] }
            ]
          },
          "options": {
            "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max", "last"] },
            "tooltip": { "mode": "multi", "sort": "desc" }
          },
          "targets": [
            { "refId": "A", "expr": "avg_over_time(zte_wan_rx_bps{connection=\"internet\"}[$__rate_interval])", "legendFormat": "PPPoE RX" },
            { "refId": "B", "expr": "avg_over_time(zte_wan_tx_bps{connection=\"internet\"}[$__rate_interval])", "legendFormat": "PPPoE TX" }
          ]
        },
        {
          "id": 62,
          "type": "timeseries",
          "title": "WAN errors",
          "gridPos": { "h": 6, "w": 12, "x": 0, "y": 49 },
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "fieldConfig": { "defaults": { "unit": "cps", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
          "targets": [
            { "refId": "A", "expr": "rate(zte_wan_errors_received_total{connection=\"internet\"}[$__rate_interval])", "legendFormat": "RX errors/s" },
            { "refId": "B", "expr": "rate(zte_wan_errors_sent_total{connection=\"internet\"}[$__rate_interval])", "legendFormat": "TX errors/s" }
          ]
        },
        {
          "id": 63,
          "type": "timeseries",
          "title": "WAN packets",
          "gridPos": { "h": 6, "w": 12, "x": 12, "y": 49 },
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "fieldConfig": { "defaults": { "unit": "pps", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
          "targets": [
            { "refId": "A", "expr": "rate(zte_wan_rx_packets_total{connection=\"internet\"}[$__rate_interval])", "legendFormat": "RX pkts/s" },
            { "refId": "B", "expr": "rate(zte_wan_tx_packets_total{connection=\"internet\"}[$__rate_interval])", "legendFormat": "TX pkts/s" }
          ]
        }
      ]
    },

    {
      "id": 70,
      "type": "row",
      "title": "LAN Port Details",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 41 },
      "collapsed": true,
      "panels": [
        {
          "id": 71,
          "type": "timeseries",
          "title": "LAN packet rate",
          "gridPos": { "h": 7, "w": 12, "x": 0, "y": 42 },
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "fieldConfig": { "defaults": { "unit": "pps", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
          "targets": [
            { "refId": "A", "expr": "rate(zte_lan_rx_packets_total{port=~\"$lan_port\"}[$__rate_interval])", "legendFormat": "{{port}} RX pps" },
            { "refId": "B", "expr": "rate(zte_lan_tx_packets_total{port=~\"$lan_port\"}[$__rate_interval])", "legendFormat": "{{port}} TX pps" }
          ]
        },
        {
          "id": 72,
          "type": "timeseries",
          "title": "LAN errors & discards",
          "gridPos": { "h": 7, "w": 12, "x": 12, "y": 42 },
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "fieldConfig": { "defaults": { "unit": "cps", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
          "targets": [
            { "refId": "A", "expr": "rate(zte_lan_rx_errors_total{port=~\"$lan_port\"}[$__rate_interval])", "legendFormat": "{{port}} RX errors/s" },
            { "refId": "B", "expr": "rate(zte_lan_tx_errors_total{port=~\"$lan_port\"}[$__rate_interval])", "legendFormat": "{{port}} TX errors/s" },
            { "refId": "C", "expr": "rate(zte_lan_rx_discards_total{port=~\"$lan_port\"}[$__rate_interval])", "legendFormat": "{{port}} RX discards/s" },
            { "refId": "D", "expr": "rate(zte_lan_tx_discards_total{port=~\"$lan_port\"}[$__rate_interval])", "legendFormat": "{{port}} TX discards/s" }
          ]
        },
        {
          "id": 73,
          "type": "table",
          "title": "LAN port status",
          "gridPos": { "h": 5, "w": 24, "x": 0, "y": 49 },
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "fieldConfig": {
            "overrides": [
              { "matcher": { "id": "byName", "options": "Value #A" }, "properties": [{ "id": "displayName", "value": "Link" }, { "id": "mappings", "value": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }] }] },
              { "matcher": { "id": "byName", "options": "Value #B" }, "properties": [{ "id": "displayName", "value": "Speed (Mbps)" }] }
            ]
          },
          "options": { "showHeader": true },
          "transformations": [
            { "id": "seriesToColumns", "options": { "byField": "port" } },
            { "id": "organize", "options": { "excludeByName": { "Time": true, "Time 1": true, "Time 2": true } } }
          ],
          "targets": [
            { "refId": "A", "expr": "zte_lan_link_up", "format": "table", "instant": true },
            { "refId": "B", "expr": "zte_lan_speed_mbps", "format": "table", "instant": true }
          ]
        }
      ]
    }
  ]
}
